          "footerText": "Manage your subscription",
          "headerType": "none"
        }
      }
    },
    {
      "id": "pause-sub",
      "type": "ManageSubscription",
      "label": "Pause Subscription",
      "x": 1150,
      "y": 300,
      "config": {
        "properties": {
          "label": "Pause Subscription",
          "action": "pause",
          "subscriptionId": "{{session.subscriptionId}}"
        }
      }
    },
    {
      "id": "pause-confirm",
      "type": "TextBlock",
      "label": "Pause Confirmed",
      "x": 1400,
      "y": 300,
      "config": {
        "text": "⏸️ Your subscription has been paused. You can resume it anytime!",
        "label": "Pause Confirmed"
      }
    },
    {
      "id": "resume-sub",
      "type": "ManageSubscription",
      "label": "Resume Subscription",
      "x": 1150,
      "y": 400,
      "config": {
        "properties": {
          "label": "Resume Subscription",
          "action": "resume",
          "subscriptionId": "{{session.subscriptionId}}"
        }
      }
    },
    {
      "id": "resume-confirm",
      "type": "TextBlock",
      "label": "Resume Confirmed",
      "x": 1400,
      "y": 400,
      "config": {
        "text": "▶️ Your subscription is back on! Deliveries will resume as scheduled.",
        "label": "Resume Confirmed"
      }
    },
    {
      "id": "cancel-sub",
      "type": "ManageSubscription",
      "label": "Cancel Subscription",
      "x": 1150,
      "y": 500,
      "config": {
        "properties": {
          "label": "Cancel Subscription",
          "action": "cancel",
          "subscriptionId": "{{session.subscriptionId}}"
        }
      }
    },
    {
      "id": "cancel-confirm",
      "type": "TextBlock",
      "label": "Cancel Confirmed",
      "x": 1400,
      "y": 500,
      "config": {
        "text": "❌ Your subscription has been cancelled. We're sorry to see you go!\nYou can start a new subscription anytime.",
        "label": "Cancel Confirmed"
      }
    },
    {
      "id": "manage-end",
      "type": "End",
      "label": "End (Manage)",
      "x": 1650,
      "y": 400,
      "config": {}
    },
    {
      "id": "end-node",
      "type": "End",
      "label": "End (Success)",
      "x": 3868,
      "y": 238,
      "config": {}
